# === MatterMiner Agentic AI — Environment Configuration ===
# Copy this file to .env and fill in your values.

PYTHON_PATH=.

# --- Required ---
OPENAI_API_KEY=your-openai-api-key-here

# --- External Services ---
NODE_REMOTE_SERVICE_URL=https://dev.matterminer.com
NODE_SERVICE_URL=http://localhost:3005

# --- CORS (comma-separated list, or override in config.py) ---
# CORS_ALLOWED_ORIGINS=["https://app.matterminer.com","https://dev.matterminer.com","http://localhost:3000"]

# --- TLS Verification ---
# Set to True (default, secure) or False (dev only with self-signed certs)
# TLS_VERIFY=True

# --- Pinecone (Memory Agent) ---
# PINECONE_API_KEY=
# PINECONE_HOST=

# --- Redis (Context Awareness) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# --- JWT Security (SEC-05) ---
JWT_ENABLED=True
JWT_SECRET=your-HS256-secret-or-RS256-public-key
JWT_ALGORITHM=HS256

# --- Privacy Guardrails (SEC-06) ---
PII_REDACTION_ENABLED=True

# --- Sentry ---
# SENTRY_DSN=
